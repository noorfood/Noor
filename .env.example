# Noor Foods Production Environment variables
# Use this as a template for your .env file

# Core Django Settings
DJANGO_SECRET_KEY=your-long-random-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (PostgreSQL)
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://noor_user:password@localhost:5432/noor_foods_db

# Security
SECURE_SSL_REDIRECT=True

# Static/Media (if different from default)
# STATIC_ROOT=/path/to/static
# MEDIA_ROOT=/path/to/media
